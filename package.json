{
  "name": "six-cities",
  "version": "4.0.0",
  "description": "Проект «Шесть городов» от HTML Academy",
  "keywords": [
    "rest",
    "api",
    "node.js"
  ],
  "main": "main.js",
  "bin": {
    "six-cities": "./dist/main.cli.js"
  },
  "scripts": {
    "start": "npm run build && node ./dist/main.js",
    "build": "tsc",
    "lint": "eslint src/ --ext .ts",
    "compile": "tsc -p tsconfig.json",
    "clean": "rimraf dist",
    "ts": "ts-node",
    "cli": "node ./dist/main.cli.js",
    "mock:server": "json-server --watch ./mocks/mock-server-data.json --port 3123",
    "start:dev": "node ./dist/main.rest.js | pino-pretty"
  },
  "devDependencies": {
    "@types/convict": "^6.1.6",
    "@types/express": "^5.0.6",
    "@types/node": "18.16.3",
    "@typescript-eslint/eslint-plugin": "5.46.0",
    "@typescript-eslint/parser": "5.46.0",
    "eslint": "8.39.0",
    "eslint-config-htmlacademy": "9.1.1",
    "json-server": "^1.0.0-beta.13",
    "pino-pretty": "^13.1.3",
    "rimraf": "^5.0.0",
    "ts-node": "10.9.1",
    "typescript": "^6.0.2"
  },
  "type": "module",
  "engines": {
    "node": "^18.0.0",
    "npm": ">=8"
  },
  "dependencies": {
    "@typegoose/typegoose": "^13.2.1",
    "axios": "^1.13.6",
    "chalk": "^5.6.2",
    "convict": "^6.2.5",
    "convict-format-with-validator": "^6.2.0",
    "crypto": "^1.0.1",
    "dotenv": "^17.3.1",
    "express": "^5.2.1",
    "http-status-codes": "^2.3.0",
    "inversify": "^8.1.0",
    "mongoose": "~9.2.2",
    "pino": "^10.3.1",
    "reflect-metadata": "^0.2.2"
  }
}
